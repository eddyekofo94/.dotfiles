theme = catppuccin-mocha

# Pin the native Apple Silicon Homebrew shell instead of inheriting a stale
# /usr/local/bin/fish path from the GUI environment.
command = /opt/homebrew/bin/fish --login

# Font
# font-family = "Jetbrains Mono"
font-family = "CommitMono Nerd Font"
font-size = 17
font-feature = zero
font-feature = calt
font-feature = liga

cursor-style-blink = true

cursor-color = f5e0dc
selection-invert-fg-bg = true

# Padding
window-padding-x = 1
window-padding-y = 5

# Enable cursor styling from apps (neovim)
shell-integration-features = cursor

# Window
# window-decoration = false
# macos-titlebar-style = "hidden"

macos-option-as-alt = left

# Key bindings
keybind = ctrl+space=unbind
