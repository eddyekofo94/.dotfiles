#!/usr/bin/env python3
import os
import re
import shlex
import signal
import subprocess
import sys
import time


def binding(prefix: str) -> str:
    for index, argument in enumerate(sys.argv[1:]):
        if argument == "--bind" and index + 2 <= len(sys.argv[1:]):
            candidate = sys.argv[index + 2]
            if candidate.startswith(prefix):
                return candidate
        if argument.startswith("--bind="):
            candidate = argument.removeprefix("--bind=")
            if candidate.startswith(prefix):
                return candidate
    return ""


def substitute(command: str, query: str) -> str:
    replacements = {
        "{q}": shlex.quote(query),
        "{1}": shlex.quote("fixture.txt"),
        "{2}": "1",
        "{3}": "1",
        "{4..}": shlex.quote("ab match"),
    }
    for placeholder, value in replacements.items():
        command = command.replace(placeholder, value)
    return command


def main() -> int:
    event = os.environ.get("FIF_FZF_EVENT", "change")
    query = os.environ.get("FIF_FZF_QUERY", "")

    if event == "interrupt":
        os.kill(os.getppid(), signal.SIGTERM)
        time.sleep(0.2)
        return 130

    if event == "preview":
        try:
            preview_index = sys.argv.index("--preview")
            command = sys.argv[preview_index + 1]
        except (ValueError, IndexError):
            print("mock fzf: preview command missing", file=sys.stderr)
            return 2
        started = time.monotonic()
        result = subprocess.run(
            ["sh", "-c", substitute(command, query)],
            check=False,
            env=os.environ,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        elapsed = time.monotonic() - started
        with open(os.environ["FIF_PREVIEW_TIMING_LOG"], "w", encoding="utf-8") as log:
            log.write(f"{elapsed:.6f}\n")
        return result.returncode

    if event == "start":
        action = binding("start:reload:")
        command = action.removeprefix("start:reload:")
    else:
        action = binding("change:reload(")
        match = re.match(r"change:reload\((.*)\)\+transform-search", action)
        command = match.group(1) if match else ""

    if not command:
        return 0
    return subprocess.run(
        ["sh", "-c", substitute(command, query)],
        check=False,
        env=os.environ,
        stdout=subprocess.DEVNULL,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main())
