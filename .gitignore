# Backups created during install are stored here, so ignore them
/.backups

# Dot stores some files in here to speed up startup times
/.cache

# During install, plugin executables will be symlinked into here so we only
# search a single directory for executables based on the shell and context
/.path
./fish/fish_variables
fish/fish_variables
**/core.*
**.zhistory
zsh/.zhistory
zsh/.zcompdump
**/*.zwc
doit/build/**
CMakeFile

# Timestamped backups left by migrations / manual edits (e.g. the Apple Silicon
# move). NOTE: no blanket *.bak — git/etc/gitconfig.bak and zsh/extras/.zshrc.bak
# are tracked on purpose.
*.pre-apple-silicon-fix.*
*.pre-modernize.*
/tmux/tmux.conf.bak

# Whole-dir backups and debug/scratch artifacts
/fish.bak/
/fish/debug_reports/
/fish/test-*.fish
/fish/file1
/fish/file2
/fish/mock_file.txt
